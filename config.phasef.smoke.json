{
  "catalog": {
    "plugins_dir": "plugins"
  },
  "scanner": {
    "intervals": ["30m"],
    "kline_buffer_size": 240,
    "max_streams_per_connection": 512,
    "warmup_request_delay_ms": 0,
    "warmup_initial_limit": 200,
    "warmup_concurrency": 6,
    "backfill_enabled": true,
    "backfill_concurrency": 1,
