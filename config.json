      "type": "donchian_5_20_crossover",
      "intervals": ["1d", "4h", "1h", "30m"],
      "scan_interval_seconds": 900,
      "max_hold_duration_seconds": 86400,
      "risk_pct": 0.01,
      "sl_multiplier": 1.5,
      "tp_multiplier": 3.0,
      "min_notional": 1.0,
      "atr_period": 14,
      "min_confidence": 0.5,
      "params": {
        "short_period": 5,
        "long_period": 20
      }
    }
  ],
  "legacy_trading_engine": {
    "symbol": "BTCUSDT",
    "interval": "15m",
    "tradeQuantity": 0.001,
    "stopLossPercent": 0.0,
    "takeProfitPercent": 4.0,
    "rsiPeriod": 14,
    "rsiOversold": 30.0,
    "rsiOverbought": 70.0,
    "smaShortPeriod": 9,
    "smaLongPeriod": 21,
    "pollIntervalMs": 60000
  }
