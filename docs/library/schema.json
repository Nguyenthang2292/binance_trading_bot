{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "LibraryIndex",
  "description": "Internal document library index — auto-generated by tools/build_library_index.py",
  "type": "object",
  "required": ["generator", "version", "entries"],
  "properties": {
    "generator": {
      "type": "string"
    },
    "version": {
      "type": "string"
    },
    "entries": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["book_id", "type", "title", "authors", "year", "implemented_in", "source_file"],
        "properties": {
          "book_id": {
            "type": "string",
            "pattern": "^[a-z0-9-]+$",
            "description": "Unique slug: <lastname>-<year>-<short-title>"
          },
          "type": {
            "type": "string",
            "enum": ["book", "paper", "online"]
          },
          "title": {
            "type": "string"
          },
          "authors": {
            "type": "array",
            "items": { "type": "string" },
            "minItems": 1
          },
          "year": {
            "type": "integer",
            "minimum": 1900,
            "maximum": 2100
          },
          "publisher": {
            "type": ["string", "null"]
          },
          "identifiers": {
            "type": "object",
            "properties": {
              "isbn_hardback": { "type": ["string", "null"] },
              "isbn_pdf":      { "type": ["string", "null"] },
              "isbn_epub":     { "type": ["string", "null"] },
              "lccn":          { "type": ["string", "null"] },
              "doi":           { "type": ["string", "null"] },
              "url":           { "type": ["string", "null"] }
            },
            "additionalProperties": false
          },
          "purchase_url": {
            "type": ["string", "null"]
          },
          "implemented_in": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["file"],
              "properties": {
                "chapter": { "type": "string" },
                "file":    { "type": "string" }
              },
              "additionalProperties": false
            }
          },
          "source_file": {
            "type": "string",
            "description": "Path to the 00-book-references.md that generated this entry"
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
